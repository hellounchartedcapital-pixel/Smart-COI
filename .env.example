# =============================================================================
# SmartCOI — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================================

# --- Supabase (required) ---
# Find these in your Supabase project dashboard under Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Supabase service role (server-side only) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Anthropic / Claude AI (server-side only) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# --- Resend email service (server-side only) ---
RESEND_API_KEY=your-resend-api-key-here

# --- Stripe billing (server-side only) ---
# Find these in your Stripe dashboard under Developers > API keys / Webhooks
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret-here

# --- Stripe price IDs (Apr 2026 freemium tiers) ---
# NEXT_PUBLIC_ prefix is required so the billing page can render the right
# checkout link client-side. Create the products + prices in the Stripe
# dashboard and paste the IDs here. Any blank entry disables that tier's
# CTA (checkout button will be disabled with a "coming soon" state).
#
# Monitor   — $79/mo or $63.20/mo billed annually ($758.40/yr)
NEXT_PUBLIC_STRIPE_PRICE_MONITOR_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_MONITOR_ANNUAL=price_xxx
# Automate  — $149/mo or $119.20/mo billed annually ($1,430.40/yr)
NEXT_PUBLIC_STRIPE_PRICE_AUTOMATE_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_AUTOMATE_ANNUAL=price_xxx
# Full Platform — $249/mo or $199.20/mo billed annually ($2,390.40/yr)
NEXT_PUBLIC_STRIPE_PRICE_FULL_PLATFORM_MONTHLY=price_xxx
NEXT_PUBLIC_STRIPE_PRICE_FULL_PLATFORM_ANNUAL=price_xxx

# --- Cron job secret (server-side only) ---
CRON_SECRET=your-cron-secret-here

# --- Application URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
